<script>
(function(){
  var t=document.getElementById('menu-toggle'),m=document.getElementById('mobile-menu'),i=document.getElementById('menu-icon');
  if(t){t.addEventListener('click',function(){m.classList.toggle('hidden');i.textContent=m.classList.contains('hidden')?'menu':'close';});}
})();
// Collapsing header
(function(){
  var hero=document.getElementById('hero-section');
  var header=document.getElementById('site-header');
  if(!hero||!header)return;
  function tick(){header.classList.toggle('compact',hero.getBoundingClientRect().bottom<=0);}
  window.addEventListener('scroll',tick,{passive:true});
  tick();
})();
</script>
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", function(user) {
      if (!user) {
        window.netlifyIdentity.on("login", function() {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>

---
layout: base.njk
title: "Servicios - Hospital de Frutillar"
description: "Conozca los servicios clínicos y de apoyo del Hospital de Frutillar: Urgencia, Hospitalización, Laboratorio, Imagenología y más."
permalink: servicios.html
---
<style>
  .banner-top { position: relative; }
  .banner-top::before { content:''; position:absolute; top:0; left:0; width:55%; height:3px; background:#0F69C4; }
  .banner-top::after  { content:''; position:absolute; top:0; left:55%; width:45%; height:3px; background:#DA291C; }
</style>

<!-- PAGE BANNER -->
<section class="text-white py-8" style="background: linear-gradient(100deg, #0B4F96 0%, #0F69C4 100%);">
  <div class="container mx-auto px-4">
    <div class="flex items-center gap-2 text-primary-light/80 text-xs mb-3 flex-wrap">
      <a href="/" class="hover:text-white transition-colors">Inicio</a>
      <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
      <span>Servicios</span>
    </div>
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 bg-white/15 rounded-full flex items-center justify-center flex-shrink-0">
        <span aria-hidden="true" class="material-symbols-outlined text-2xl">medical_services</span>
      </div>
      <div>
        <h2 class="font-sans text-2xl md:text-3xl font-bold">Servicios Clínicos y de Apoyo</h2>
        <p class="text-white/65 text-sm mt-0.5">Conozca la oferta de servicios del Hospital de Frutillar</p>
      </div>
    </div>
  </div>
</section>

<main id="main-content" class="container mx-auto px-4 py-8">

  <div class="flex items-center gap-2 text-xs text-gray-400 mb-6">
    <a href="/" class="hover:text-primary transition-colors">Inicio</a>
    <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
    <span class="text-primary font-semibold">Servicios</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-7 items-start">

    <div style="min-width:0;" class="flex flex-col gap-7">

      <div class="mb-2">
        <h2 class="font-sans text-2xl font-bold text-primary border-l-4 border-primary-light pl-3 mb-1">Servicios Clínicos y de Apoyo</h2>
        <p class="text-sm text-gray-500 pl-4">Conozca la oferta de servicios del Hospital de Frutillar</p>
      </div>

      {% for s in servicios.servicios %}
      <div id="{{ s.id }}" class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary px-5 py-3 flex items-center gap-2">
          <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-xl">{{ s.icon }}</span>
          <h2 class="text-white font-bold text-base tracking-wide uppercase">{{ s.nombre }}</h2>
        </div>
        <div class="px-6 py-5 flex flex-col gap-3">
          <p class="text-sm text-gray-700 leading-relaxed">{{ s.descripcion }}</p>
          {% if s.horario %}
          <div class="flex items-start gap-2 text-sm text-primary bg-primary-bg border border-primary-pale rounded-custom px-4 py-3">
            <span aria-hidden="true" class="material-symbols-outlined text-primary-light mt-0.5 text-base">{{ s.horario_icon }}</span>
            <span>{{ s.horario }}</span>
          </div>
          {% elif s.ubicacion %}
          <div class="flex items-start gap-2 text-sm text-primary bg-primary-bg border border-primary-pale rounded-custom px-4 py-3">
            <span aria-hidden="true" class="material-symbols-outlined text-primary-light mt-0.5 text-base">{{ s.horario_icon }}</span>
            <span>{{ s.ubicacion }}</span>
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}

    </div>

    <aside class="flex flex-col gap-5">
      <div class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary-dark text-white text-xs font-bold uppercase tracking-widest px-4 py-2.5">Servicios</div>
        <div class="flex flex-col">
          {% for s in servicios.servicios %}
          <a href="#{{ s.id }}" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">{{ s.icon }}</span>
            <strong class="text-sm text-primary">{{ s.nombre }}</strong>
          </a>
          {% endfor %}
        </div>
      </div>

      <div class="flex flex-col gap-2.5">
        <a href="/horarios.html" class="banner-top bg-gray-50 border border-gray-200 rounded-custom px-5 py-4 shadow-sm hover:shadow-md transition-all flex items-center justify-center min-h-[64px] text-center">
          <span class="text-primary text-sm font-extrabold uppercase tracking-tight">Horarios de Atención</span>
        </a>
        <a href="/carta-derechos.html" class="banner-top bg-gray-50 border border-gray-200 rounded-custom px-5 py-4 shadow-sm hover:shadow-md transition-all flex items-center justify-center min-h-[64px] text-center">
          <span class="text-primary text-sm font-extrabold uppercase tracking-tight leading-tight">Carta de Derechos y Deberes</span>
        </a>
        <a href="tel:600-360-7777" class="banner-top bg-gray-50 border border-gray-200 rounded-custom px-5 py-4 shadow-sm hover:shadow-md transition-all flex items-center gap-4 min-h-[64px]">
          <div class="bg-primary text-white p-2 rounded-full flex-shrink-0">
            <span aria-hidden="true" class="material-symbols-outlined text-xl">call</span>
          </div>
          <div>
            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block">Salud Responde</span>
            <span class="text-primary text-xl font-black leading-none">{{ site.telefono }}</span>
          </div>
        </a>
      </div>
    </aside>
  </div>
</main>

---
layout: base.njk
title: "Quiénes Somos - Hospital de Frutillar"
description: "Misión, visión, historia y autoridades del Hospital de Frutillar."
permalink: quienes-somos.html
---
<style>
  .hito { border-left: 3px solid #6AADEB; }
  .banner-top { position: relative; }
  .banner-top::before { content:''; position:absolute; top:0; left:0; width:55%; height:3px; background:#0F69C4; }
  .banner-top::after  { content:''; position:absolute; top:0; left:55%; width:45%; height:3px; background:#DA291C; }
</style>

<!-- PAGE BANNER -->
<section class="text-white py-8" style="background: linear-gradient(100deg, #0B4F96 0%, #0F69C4 100%);">
  <div class="container mx-auto px-4">
    <div class="flex items-center gap-2 text-primary-light/80 text-xs mb-3 flex-wrap">
      <a href="/" class="hover:text-white transition-colors">Inicio</a>
      <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
      <span>Quiénes Somos</span>
    </div>
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 bg-white/15 rounded-full flex items-center justify-center flex-shrink-0">
        <span aria-hidden="true" class="material-symbols-outlined text-2xl">groups</span>
      </div>
      <div>
        <h2 class="font-sans text-2xl md:text-3xl font-bold">Quiénes Somos</h2>
        <p class="text-white/65 text-sm mt-0.5">Misión, visión, historia y autoridades del Hospital de Frutillar</p>
      </div>
    </div>
  </div>
</section>

<main id="main-content" class="container mx-auto px-4 py-8">

  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-xs text-gray-400 mb-6">
    <a href="/" class="hover:text-primary transition-colors">Inicio</a>
    <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
    <span class="text-primary font-semibold">Quiénes Somos</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-7 items-start">

    <!-- COLUMNA PRINCIPAL -->
    <div style="min-width:0;" class="flex flex-col gap-7">

      <!-- MISIÓN -->
      <div id="mision" class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary px-5 py-3 flex items-center gap-2">
          <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-xl">flag</span>
          <h2 class="text-white font-bold text-base tracking-wide uppercase">Misión</h2>
        </div>
        <div class="px-6 py-5">
          <p class="text-gray-700 leading-relaxed text-sm">{{ quienes_somos.mision }}</p>
        </div>
      </div>

      <!-- VISIÓN -->
      <div id="vision" class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary px-5 py-3 flex items-center gap-2">
          <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-xl">visibility</span>
          <h2 class="text-white font-bold text-base tracking-wide uppercase">Visión</h2>
        </div>
        <div class="px-6 py-5">
          <p class="text-gray-700 leading-relaxed text-sm">{{ quienes_somos.vision }}</p>
        </div>
      </div>

      <!-- HISTORIA -->
      <div id="historia" class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary px-5 py-3 flex items-center gap-2">
          <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-xl">history_edu</span>
          <h2 class="text-white font-bold text-base tracking-wide uppercase">Historia del Hospital</h2>
        </div>
        <div class="px-6 py-6 flex flex-col gap-6">
          <!-- Fotografía placeholder -->
          <div class="w-full rounded-custom overflow-hidden border border-gray-200 bg-gradient-to-br from-primary-dark to-primary flex items-center justify-center flex-col gap-2" style="height:280px;">
            <span aria-hidden="true" class="material-symbols-outlined text-white/30" style="font-size:64px;">photo_camera</span>
            <p class="text-white/40 text-xs font-semibold uppercase tracking-widest">Fotografía histórica del hospital</p>
            <p class="text-white/25 text-xs">Reemplazar con imagen real</p>
          </div>
          <!-- Texto histórico -->
          <div class="prose max-w-none text-sm text-gray-700 leading-relaxed">
            {{ quienes_somos.historia | markdown | safe }}
          </div>
        </div>
      </div>

      <!-- AUTORIDADES -->
      <div id="autoridades" class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary px-5 py-3 flex items-center gap-2">
          <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-xl">groups</span>
          <h2 class="text-white font-bold text-base tracking-wide uppercase">Autoridades</h2>
        </div>
        <div class="px-6 py-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% for a in quienes_somos.autoridades %}
            <div class="flex items-start gap-4 bg-gray-50 border border-gray-100 rounded-custom p-4">
              <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center flex-shrink-0">
                {% if a.foto %}
                  <img src="{{ a.foto }}" alt="{{ a.nombre }}" class="w-full h-full object-cover rounded-full">
                {% else %}
                  <span aria-hidden="true" class="material-symbols-outlined text-white text-xl">person</span>
                {% endif %}
              </div>
              <div>
                <p class="text-xs font-bold text-primary-light uppercase tracking-wide mb-0.5">{{ a.cargo }}</p>
                <p class="text-sm font-semibold text-gray-800">{{ a.nombre }}</p>
                <p class="text-xs text-gray-500">{{ a.unidad }}</p>
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>

      <!-- PLAN ESTRATÉGICO -->
      <div id="plan-estrategico" class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary px-5 py-3 flex items-center gap-2">
          <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-xl">analytics</span>
          <h2 class="text-white font-bold text-base tracking-wide uppercase">Plan Estratégico</h2>
        </div>
        <div class="px-6 py-6 flex flex-col gap-4">
          <div class="prose max-w-none text-sm text-gray-700 leading-relaxed">
            {{ quienes_somos.plan_estrategico | markdown | safe }}
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <div class="bg-gray-50 border border-gray-200 rounded-custom p-4 text-center">
              <span aria-hidden="true" class="material-symbols-outlined text-primary text-2xl block mb-2">my_location</span>
              <p class="text-xs font-bold text-gray-600 uppercase tracking-wide">Misión</p>
              <p class="text-xs text-gray-500 mt-1">Atención integral, oportuna y de calidad</p>
            </div>
            <div class="bg-gray-50 border border-gray-200 rounded-custom p-4 text-center">
              <span aria-hidden="true" class="material-symbols-outlined text-primary text-2xl block mb-2">visibility</span>
              <p class="text-xs font-bold text-gray-600 uppercase tracking-wide">Visión</p>
              <p class="text-xs text-gray-500 mt-1">Hospital de excelencia en la Región de Los Lagos</p>
            </div>
            <div class="bg-gray-50 border border-gray-200 rounded-custom p-4 text-center">
              <span aria-hidden="true" class="material-symbols-outlined text-primary text-2xl block mb-2">star</span>
              <p class="text-xs font-bold text-gray-600 uppercase tracking-wide">Valores</p>
              <p class="text-xs text-gray-500 mt-1">Respeto, Compromiso, Transparencia</p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- SIDEBAR -->
    <aside class="flex flex-col gap-5">
      <div class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary-dark text-white text-xs font-bold uppercase tracking-widest px-4 py-2.5">En esta sección</div>
        <div class="flex flex-col">
          <a href="#mision" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">flag</span>
            <strong class="text-sm text-primary">Misión</strong>
          </a>
          <a href="#vision" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">visibility</span>
            <strong class="text-sm text-primary">Visión</strong>
          </a>
          <a href="#historia" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">history_edu</span>
            <strong class="text-sm text-primary">Historia del Hospital</strong>
          </a>
          <a href="#autoridades" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">groups</span>
            <strong class="text-sm text-primary">Autoridades</strong>
          </a>
          <a href="#plan-estrategico" class="acceso-item flex items-center gap-3 px-4 py-3">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">analytics</span>
            <strong class="text-sm text-primary">Plan Estratégico</strong>
          </a>
        </div>
      </div>

      <div class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary-dark text-white text-xs font-bold uppercase tracking-widest px-4 py-2.5">Fechas Clave</div>
        <div class="px-4 py-4 flex flex-col gap-3">
          <div class="flex items-start gap-3">
            <span class="text-primary-light font-black text-sm whitespace-nowrap">1952</span>
            <p class="text-xs text-gray-600">Inicio de la construcción</p>
          </div>
          <div class="border-t border-gray-100 pt-3 flex items-start gap-3">
            <span class="text-primary-light font-black text-sm whitespace-nowrap">1957</span>
            <p class="text-xs text-gray-600">Inauguración oficial del hospital</p>
          </div>
          <div class="border-t border-gray-100 pt-3 flex items-start gap-3">
            <span class="text-primary-light font-black text-sm whitespace-nowrap">1957</span>
            <p class="text-xs text-gray-600">Primeros servicios: Pediatría y Maternidad</p>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-2.5">
        <a href="#plan-estrategico" class="banner-top bg-gray-50 border border-gray-200 rounded-custom px-5 py-4 shadow-sm hover:shadow-md transition-all flex items-center justify-center min-h-[64px] text-center">
          <span class="text-primary text-sm font-extrabold uppercase tracking-tight">Plan Estratégico</span>
        </a>
        <a href="#" class="banner-top bg-gray-50 border border-gray-200 rounded-custom px-5 py-4 shadow-sm hover:shadow-md transition-all flex items-center justify-center min-h-[64px] text-center">
          <span class="text-primary text-sm font-extrabold uppercase tracking-tight">Hospital Amigo</span>
        </a>
        <a href="tel:600-360-7777" class="banner-top bg-gray-50 border border-gray-200 rounded-custom px-5 py-4 shadow-sm hover:shadow-md transition-all flex items-center gap-4 min-h-[64px]">
          <div class="bg-primary text-white p-2 rounded-full flex-shrink-0">
            <span aria-hidden="true" class="material-symbols-outlined text-xl">call</span>
          </div>
          <div>
            <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block">Salud Responde</span>
            <span class="text-primary text-xl font-black leading-none">{{ site.telefono }}</span>
          </div>
        </a>
      </div>
    </aside>
  </div>
</main>

---
layout: base.njk
title: "Carta de Derechos y Deberes - Hospital de Frutillar"
description: "Sus derechos y deberes como paciente según la Ley 20.584 en el Hospital de Frutillar."
permalink: carta-derechos.html
---
<style>
  .banner-top { position: relative; }
  .banner-top::before { content:''; position:absolute; top:0; left:0; width:55%; height:3px; background:#0F69C4; }
  .banner-top::after  { content:''; position:absolute; top:0; left:55%; width:45%; height:3px; background:#DA291C; }
</style>

<!-- PAGE BANNER -->
<section class="text-white py-8" style="background: linear-gradient(100deg, #0B4F96 0%, #0F69C4 100%);">
  <div class="container mx-auto px-4">
    <div class="flex items-center gap-2 text-primary-light/80 text-xs mb-3 flex-wrap">
      <a href="/" class="hover:text-white transition-colors">Inicio</a>
      <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
      <span>Información al Usuario</span>
      <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
      <span>Carta de Derechos y Deberes</span>
    </div>
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 bg-white/15 rounded-full flex items-center justify-center flex-shrink-0">
        <span aria-hidden="true" class="material-symbols-outlined text-2xl">policy</span>
      </div>
      <div>
        <h2 class="font-sans text-2xl md:text-3xl font-bold">{{ carta_derechos.titulo }}</h2>
        <p class="text-white/65 text-sm mt-0.5">{{ carta_derechos.intro }}</p>
      </div>
    </div>
  </div>
</section>

<main id="main-content" class="container mx-auto px-4 py-8">

  <div class="flex items-center gap-2 text-xs text-gray-400 mb-6">
    <a href="/" class="hover:text-primary transition-colors">Inicio</a>
    <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
    <a href="/horarios.html" class="hover:text-primary transition-colors">Información al Usuario</a>
    <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
    <span class="text-primary font-semibold">Carta de Derechos y Deberes</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-7 items-start">

    <div style="min-width:0;" class="flex flex-col gap-6">

      <!-- DERECHOS -->
      <div class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary px-5 py-3 flex items-center gap-2">
          <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-xl">verified_user</span>
          <h2 class="text-white font-bold text-base tracking-wide uppercase">Sus Derechos como Paciente</h2>
        </div>
        <div class="px-6 py-6 flex flex-col gap-3">
          <p class="text-sm text-gray-600 leading-relaxed">La <strong class="text-primary">Ley N° 20.584</strong> garantiza los siguientes derechos a toda persona en su atención de salud:</p>
          <ol class="flex flex-col gap-3">
            {% for d in carta_derechos.derechos %}
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary text-white text-xs font-bold flex items-center justify-center mt-0.5">{{ loop.index }}</span>
              <div>
                <p class="text-sm font-semibold text-gray-800">{{ d.titulo }}</p>
                <p class="text-sm text-gray-600">{{ d.descripcion }}</p>
              </div>
            </li>
            {% endfor %}
          </ol>
          <a href="https://www.minsal.cl" target="_blank" class="inline-flex items-center gap-2 bg-gray-100 text-primary text-sm font-bold px-4 py-2.5 rounded-custom hover:bg-primary-bg transition-colors w-fit border border-gray-200 mt-2">
            <span aria-hidden="true" class="material-symbols-outlined text-base">open_in_new</span>
            Texto completo en MINSAL
          </a>
        </div>
      </div>

      <!-- DEBERES -->
      <div class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary-dark px-5 py-3 flex items-center gap-2">
          <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-xl">assignment</span>
          <h2 class="text-white font-bold text-base tracking-wide uppercase">Sus Deberes como Paciente</h2>
        </div>
        <div class="px-6 py-6">
          <ul class="flex flex-col gap-3">
            {% for d in carta_derechos.deberes %}
            <li class="flex items-start gap-3 text-sm">
              <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-base mt-0.5 flex-shrink-0">check_circle</span>
              <span class="text-gray-700"><strong class="text-gray-800">{{ d.titulo }}:</strong> {{ d.descripcion }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>
      </div>

      <!-- OIRS -->
      <div class="bg-primary-bg border border-primary-pale rounded-custom p-5 flex items-start gap-3">
        <span aria-hidden="true" class="material-symbols-outlined text-primary mt-0.5 flex-shrink-0">support_agent</span>
        <div>
          <p class="text-sm font-bold text-primary mb-1">OIRS — Oficina de Informaciones, Reclamos y Sugerencias</p>
          <p class="text-sm text-gray-700">{{ carta_derechos.oirs_descripcion }}</p>
        </div>
      </div>

    </div>

    <aside class="flex flex-col gap-5">
      <div class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary-dark text-white text-xs font-bold uppercase tracking-widest px-4 py-2.5">Información al Usuario</div>
        <div class="flex flex-col">
          <a href="/horarios.html" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">schedule</span>
            <strong class="text-sm text-primary">Horarios de Atención</strong>
          </a>
          <a href="/carta-derechos.html" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100" style="border-left-color:#0F69C4; background:#EEF4FB;">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">verified_user</span>
            <strong class="text-sm text-primary">Carta de Derechos y Deberes</strong>
          </a>
          <a href="/aranceles.html" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">receipt_long</span>
            <strong class="text-sm text-primary">Aranceles</strong>
          </a>
          <a href="/copago-cero.html" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">money_off</span>
            <strong class="text-sm text-primary">Copago Cero</strong>
          </a>
          <a href="/ley-ricarte-soto.html" class="acceso-item flex items-center gap-3 px-4 py-3">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">medication</span>
            <strong class="text-sm text-primary">Ley Ricarte Soto</strong>
          </a>
        </div>
      </div>
      <a href="tel:600-360-7777" class="banner-top bg-gray-50 border border-gray-200 rounded-custom px-5 py-4 shadow-sm hover:shadow-md transition-all flex items-center gap-4 min-h-[64px]">
        <div class="bg-primary text-white p-2 rounded-full flex-shrink-0">
          <span aria-hidden="true" class="material-symbols-outlined text-xl">call</span>
        </div>
        <div>
          <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block">Salud Responde</span>
          <span class="text-primary text-xl font-black leading-none">{{ site.telefono }}</span>
        </div>
      </a>
    </aside>
  </div>
</main>

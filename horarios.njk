---
layout: base.njk
title: "Horarios de Atención - Hospital de Frutillar"
description: "Información actualizada de horarios de atención por servicio y especialidad del Hospital de Frutillar."
permalink: horarios.html
---
<style>
  .banner-top { position: relative; }
  .banner-top::before { content:''; position:absolute; top:0; left:0; width:55%; height:3px; background:#0F69C4; }
  .banner-top::after  { content:''; position:absolute; top:0; left:55%; width:45%; height:3px; background:#DA291C; }
</style>

<!-- PAGE BANNER -->
<section class="text-white py-8" style="background: linear-gradient(100deg, #0B4F96 0%, #0F69C4 100%);">
  <div class="container mx-auto px-4">
    <div class="flex items-center gap-2 text-primary-light/80 text-xs mb-3 flex-wrap">
      <a href="/" class="hover:text-white transition-colors">Inicio</a>
      <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
      <span>Información al Usuario</span>
      <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
      <span>Horarios de Atención</span>
    </div>
    <div class="flex items-center gap-4">
      <div class="w-12 h-12 bg-white/15 rounded-full flex items-center justify-center flex-shrink-0">
        <span aria-hidden="true" class="material-symbols-outlined text-2xl">schedule</span>
      </div>
      <div>
        <h2 class="font-sans text-2xl md:text-3xl font-bold">Horarios de Atención</h2>
        <p class="text-white/65 text-sm mt-0.5">Información actualizada de horarios por servicio y especialidad</p>
      </div>
    </div>
  </div>
</section>

<main id="main-content" class="container mx-auto px-4 py-8">

  <div class="flex items-center gap-2 text-xs text-gray-400 mb-6">
    <a href="/" class="hover:text-primary transition-colors">Inicio</a>
    <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
    <span>Información al Usuario</span>
    <span aria-hidden="true" class="material-symbols-outlined text-sm">chevron_right</span>
    <span class="text-primary font-semibold">Horarios de Atención</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-7 items-start">

    <div style="min-width:0;">

      <div class="mb-6">
        <h2 class="font-sans text-2xl font-bold text-primary border-l-4 border-primary-light pl-3 mb-1">Horarios de Atención</h2>
        <p class="text-sm text-gray-500 pl-4">Información actualizada de los horarios de atención por servicio</p>
      </div>

      <div class="flex items-start gap-3 bg-primary-bg border border-primary-light rounded-custom px-4 py-3 mb-7 text-sm text-primary">
        <span aria-hidden="true" class="material-symbols-outlined text-primary-light mt-0.5">info</span>
        <p>{{ horarios.intro }}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {% for s in horarios.servicios %}
        <div class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden hover:shadow-md transition-shadow{% if s.span2 %} md:col-span-2{% endif %}">
          <div class="bg-primary px-4 py-3 flex items-center gap-2">
            <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-xl">{{ s.icon }}</span>
            <h3 class="text-white font-bold text-sm">{{ s.nombre }}</h3>
          </div>
          <div class="px-4 py-4">
            {% if s.descripcion %}
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">{{ s.descripcion }}</p>
            {% endif %}
            <div class="flex flex-col gap-2 text-sm text-gray-700">
              {% for h in s.horarios %}
              <div class="flex items-start gap-2">
                <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-base mt-0.5">calendar_today</span>
                <span>{{ h.dias }}: <strong>{{ h.horario }}</strong></span>
              </div>
              {% endfor %}
              {% if s.notas %}
              <p class="text-xs text-gray-400 mt-1">{{ s.notas }}</p>
              {% endif %}
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

    <aside class="flex flex-col gap-5">
      <div class="bg-white border border-gray-200 rounded-custom shadow-sm overflow-hidden">
        <div class="bg-primary-dark text-white text-xs font-bold uppercase tracking-widest px-4 py-2.5">Accesos Rápidos</div>
        <div class="flex flex-col">
          <a href="/servicios.html#urgencia" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">emergency</span>
            <div><strong class="text-sm text-primary block">Urgencias</strong><span class="text-xs text-gray-500">Horarios y categorización</span></div>
          </a>
          <a href="/horarios.html" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100 bg-primary-bg" style="border-left-color:#0F69C4;">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">schedule</span>
            <div><strong class="text-sm text-primary block">Horarios de Atención</strong><span class="text-xs text-gray-500">Página actual</span></div>
          </a>
          <a href="/servicios.html#laboratorio" class="acceso-item flex items-center gap-3 px-4 py-3 border-b border-gray-100">
            <span aria-hidden="true" class="material-symbols-outlined text-primary text-xl">biotech</span>
            <div><strong class="text-sm text-primary block">Laboratorio</strong><span class="text-xs text-gray-500">Resultados en línea</span></div>
          </a>
        </div>
      </div>

      <a href="tel:600-360-7777" class="banner-top bg-gray-50 border border-gray-200 rounded-custom px-5 py-4 shadow-sm hover:shadow-md transition-all flex items-center gap-4 min-h-[64px]">
        <div class="bg-primary text-white p-2 rounded-full flex-shrink-0">
          <span aria-hidden="true" class="material-symbols-outlined text-xl">call</span>
        </div>
        <div>
          <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block">Salud Responde</span>
          <span class="text-primary text-xl font-black leading-none">{{ site.telefono }}</span>
        </div>
      </a>
    </aside>
  </div>
</main>

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>{{ title or site.name }}</title>
<meta name="description" content="{{ description or site.description }}">
<meta property="og:type" content="website">
<meta property="og:locale" content="es_CL">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:title" content="{{ title or site.name }}">
<meta property="og:description" content="{{ description or site.description }}">
<link href="https://fonts.googleapis.com" rel="preconnect">
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect">
<link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,1,0" rel="stylesheet">
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          sans: ['Public Sans', 'sans-serif'],
          serif: ['Public Sans', 'sans-serif'],
        },
        colors: {
          primary: {
            DEFAULT: '#0F69C4',
            light:   '#6AADEB',
            pale:    '#CCE3F7',
            bg:      '#EEF4FB',
            dark:    '#0B4F96',
          },
        },
        borderRadius: { custom: '4px' }
      }
    }
  }
</script>
<style>
  .acceso-item { border-left: 4px solid #6AADEB; transition: border-color .15s, background .15s; }
  .acceso-item:hover { border-left-color: #0F69C4; background: #EEF4FB; }
  .banner-side { position: relative; }
  .banner-side::before { content:''; position:absolute; top:0; left:0; width:50%; height:3px; background:#0F69C4; }
  .banner-side::after  { content:''; position:absolute; top:0; left:50%; width:50%; height:3px; background:#DA291C; }
  .link-card { position:relative; overflow:hidden; }
  .link-card::before { content:''; position:absolute; top:0; left:0; width:55%; height:3px; background:#0F69C4; }
  .link-card::after  { content:''; position:absolute; top:0; left:55%; width:45%; height:3px; background:#DA291C; }
  .news-card { transition: box-shadow .15s, border-color .15s; border-left: 4px solid #CCE3F7; }
  .news-card:hover { border-left-color: #0F69C4; box-shadow: 0 6px 20px rgba(0,0,0,0.08); }
  {% block extraCss %}{% endblock %}
</style>
</head>

{# Determine active nav item #}
{% set currentUrl = page.url %}
{% set isHome          = currentUrl == '/' %}
{% set isNoticias      = '/noticias' in currentUrl %}
{% set isQuienesSomos  = '/quienes-somos' in currentUrl %}
{% set isServicios     = '/servicios' in currentUrl %}
{% set isInfo          = '/horarios' in currentUrl or '/carta-derechos' in currentUrl or '/aranceles' in currentUrl or '/copago-cero' in currentUrl or '/ley-ricarte-soto' in currentUrl or '/faq' in currentUrl %}
{% set isTransparencia = '/transparencia' in currentUrl %}
{% set isTrabaja       = '/trabaja-con-nosotros' in currentUrl %}
{% set isContacto      = '/contacto' in currentUrl %}

{% macro navClass(active) %}{% if active %}text-white font-bold border-b-2 border-primary-light bg-white/15{% else %}hover:bg-white/10 hover:text-white transition-colors{% endif %}{% endmacro %}

<body class="font-sans antialiased bg-zinc-100 text-gray-800">
<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-white focus:text-primary focus:px-4 focus:py-2 focus:rounded-custom focus:shadow-lg focus:outline-none">Saltar al contenido principal</a>

<!-- BARRA DE IDENTIDAD GOBIERNO DE CHILE · GobDigital CL v3 -->
<div class="bg-white border-b border-gray-200">
  <div class="container mx-auto px-4 flex items-center justify-between py-1.5">
    <div class="flex items-center gap-2.5">
      <div class="flex items-center gap-px" aria-hidden="true">
        <span class="block w-1 h-4 rounded-sm" style="background:#DA291C;"></span>
        <span class="block w-1 h-4 rounded-sm" style="background:#0F69C4;"></span>
      </div>
      <a href="https://www.gob.cl" target="_blank" rel="noopener"
         class="text-[11px] font-semibold text-gray-500 hover:text-[#0F69C4] transition-colors tracking-wide">
        Gobierno de Chile
      </a>
    </div>
    <a href="https://www.gob.cl" target="_blank" rel="noopener"
       class="text-[11px] text-gray-400 hover:text-[#0F69C4] transition-colors hidden sm:block">
      gob.cl
    </a>
  </div>
</div>

<!-- TOPBAR -->
<div class="bg-[#27272a] text-white text-xs py-1.5 border-b border-white/10">
  <div class="container mx-auto px-4 flex justify-between items-center flex-wrap gap-2">
    <div class="flex items-center gap-1.5 text-white/65">
      <span aria-hidden="true" class="material-symbols-outlined text-xs">location_on</span>
      {{ site.direccion }} &nbsp;·&nbsp; {{ site.region }}
    </div>
    <div class="flex gap-5 text-white/65">
      <a href="#" class="hover:text-white transition-colors">Facebook</a>
      <a href="#" class="hover:text-white transition-colors">Instagram</a>
      <a href="{{ site.ssreloncavi }}" target="_blank" class="hover:text-white transition-colors">Servicio de Salud Reloncaví</a>
    </div>
  </div>
</div>

<!-- HEADER -->
<header class="text-white w-full shadow-md" style="background: linear-gradient(135deg,#0B4F96 0%,#0F69C4 55%,#3A8FD4 100%);">
  <div class="container mx-auto px-4 py-5">
    <div class="flex flex-col md:flex-row items-center justify-between gap-5">
      <div class="flex items-center gap-5">
        <a href="/">
          <div class="w-20 h-20 rounded-custom flex-shrink-0 overflow-hidden shadow-lg border-2 border-white/30">
            <img src="/img/logo-hospital.png" alt="Logo {{ site.name }}" class="w-full h-full object-cover">
          </div>
        </a>
        <div>
          <p class="text-[10px] font-bold tracking-widest uppercase text-white/60 mb-1">Trabajando para usted</p>
          <h1 class="font-sans text-3xl md:text-4xl font-bold tracking-tight leading-tight">
            <a href="/" class="hover:text-primary-light transition-colors">Hospital de <span class="text-primary-light">Frutillar</span></a>
          </h1>
          <div class="w-48 border-t-2 border-dashed border-white/30 my-1.5"></div>
          <p class="text-[11px] tracking-widest uppercase text-white/65">{{ site.servicio }}</p>
        </div>
      </div>
      <div class="flex flex-col items-center md:items-end gap-3">
        <span class="text-[10px] tracking-widest uppercase text-white/40">Gobierno de Chile</span>
        <a href="tel:6003607777" class="flex items-center gap-2 text-white/80 hover:text-white text-sm transition-colors group">
          <span aria-hidden="true" class="material-symbols-outlined text-lg text-primary-light group-hover:text-white transition-colors">call</span>
          <span>{{ site.telefonoLabel }} <strong class="text-white">{{ site.telefono }}</strong></span>
        </a>
        <a href="{{ site.portalFuncionarios }}" target="_blank" class="flex items-center gap-2 bg-white/15 hover:bg-white text-white hover:text-primary-dark font-bold text-sm px-5 py-2.5 rounded-custom transition-all shadow border border-white/30">
          <span aria-hidden="true" class="material-symbols-outlined text-base">lock</span>
          Portal Funcionarios
        </a>
      </div>
    </div>
  </div>
</header>


<script>
(function(){
  var t=document.getElementById('menu-toggle'),m=document.getElementById('mobile-menu'),i=document.getElementById('menu-icon');
  if(t){t.addEventListener('click',function(){m.classList.toggle('hidden');i.textContent=m.classList.contains('hidden')?'menu':'close';});}
  document.querySelectorAll('.mobile-submenu-btn').forEach(function(b){
    b.addEventListener('click',function(){
      var s=document.getElementById(this.dataset.target);
      s.classList.toggle('hidden');
      this.querySelector('.expand-icon').textContent=s.classList.contains('hidden')?'expand_more':'expand_less';
    });
  });
})();
</script>

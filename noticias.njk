---
layout: base.njk
title: "Noticias - Hospital de Frutillar"
description: "Últimas noticias e información del Hospital de Frutillar, Servicio de Salud Reloncaví."
permalink: noticias.html
---
<main class="container mx-auto px-4 py-10">
  <div class="flex items-center gap-3 mb-8">
    <span aria-hidden="true" class="material-symbols-outlined text-primary-light text-2xl">newspaper</span>
    <h2 class="font-sans text-2xl font-bold text-primary-DEFAULT">Noticias</h2>
    <div class="h-px bg-gray-200 flex-1"></div>
  </div>

  {% if collections.noticias.length %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for noticia in collections.noticias %}
        <article class="news-card bg-white rounded-custom shadow-sm overflow-hidden flex flex-col">
          <div class="relative h-36 overflow-hidden" style="background: linear-gradient(135deg, #0A2A5E 0%, #0F69C4 60%, #3A8FD4 100%);">
            {% if noticia.data.imagen %}
              <img src="{{ noticia.data.imagen }}" alt="{{ noticia.data.title }}" class="w-full h-full object-cover">
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
            {% else %}
              <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
                <span class="material-symbols-outlined text-white/10" style="font-size:80px; line-height:1;">article</span>
              </div>
            {% endif %}
            <div class="absolute top-2 left-2">
              <span class="inline-block px-2 py-0.5 bg-primary-DEFAULT text-white text-[9px] font-bold uppercase tracking-wider rounded">{{ noticia.data.categoria }}</span>
            </div>
          </div>
          <div class="p-4 flex flex-col flex-1">
            <p class="text-xs text-gray-400 mb-1">{{ noticia.date | fechaES }}</p>
            <h3 class="font-sans font-bold text-gray-800 text-sm leading-snug mb-2 flex-1">{{ noticia.data.title }}</h3>
            <p class="text-xs text-gray-500 leading-relaxed mb-3 line-clamp-3">{{ noticia.data.resumen }}</p>
            <a href="{{ noticia.url }}" class="inline-flex items-center gap-1.5 text-primary-DEFAULT text-xs font-bold hover:underline mt-auto">
              Leer más
              <span aria-hidden="true" class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
          </div>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="text-gray-500 text-center py-16">No hay noticias publicadas aún.</p>
  {% endif %}
</main>
